{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://cinrbhapzhbrolzczkrn.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "lexguild-mcp",
      "version": "0.2.0",
      "title": "LexGuild"
    },
    "tools": [
      {
        "name": "whoami",
        "title": "Who am I",
        "description": "Return the LexGuild profile of the signed-in user (name, email, bar info).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_my_organizations",
        "title": "List my organizations",
        "description": "List the LexGuild organizations (bar associations / law firms) the signed-in user belongs to.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_qa_posts",
        "title": "List Q&A posts",
        "description": "List recent Q&A posts (questions/discussions) in a LexGuild organization the user belongs to. Ordered by most recent activity. Returns at most `limit` posts (default 20, max 50).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "organizationId": {
              "type": "string",
              "format": "uuid",
              "description": "Organization ID (from list_my_organizations)."
            },
            "limit": {
              "type": "integer",
              "description": "Max posts to return, 1-50. Default 20."
            },
            "search": {
              "type": "string",
              "description": "Optional full-text search term (matches title/body/tags)."
            }
          },
          "required": [
            "organizationId"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_qa_post",
        "title": "Get Q&A post with replies",
        "description": "Fetch a single Q&A post and its replies. Only returns posts in organizations the signed-in user belongs to.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "postId": {
              "type": "string",
              "format": "uuid",
              "description": "Q&A post ID."
            }
          },
          "required": [
            "postId"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "create_qa_post",
        "title": "Create Q&A post",
        "description": "Post a new question or discussion in a LexGuild organization the signed-in user belongs to. Returns the created post ID.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "organizationId": {
              "type": "string",
              "format": "uuid",
              "description": "Organization ID to post in."
            },
            "title": {
              "type": "string",
              "description": "Short question title."
            },
            "body": {
              "type": "string",
              "description": "Full question body (markdown supported)."
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Optional list of tags."
            },
            "isUrgent": {
              "type": "boolean",
              "description": "Mark the question as urgent."
            },
            "isAnonymous": {
              "type": "boolean",
              "description": "Post anonymously (author hidden to other members)."
            },
            "categoryId": {
              "type": "string",
              "format": "uuid",
              "description": "Optional Q&A category ID."
            }
          },
          "required": [
            "organizationId",
            "title",
            "body"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "reply_to_qa_post",
        "title": "Reply to a Q&A post",
        "description": "Add a reply to an existing Q&A post. Requires the signed-in user to be a member of the post's organization.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "postId": {
              "type": "string",
              "format": "uuid",
              "description": "Q&A post to reply to."
            },
            "body": {
              "type": "string",
              "description": "Reply body (markdown supported)."
            },
            "isPrivate": {
              "type": "boolean",
              "description": "Private reply visible only to the post author (if the post allows it)."
            },
            "parentReplyId": {
              "type": "string",
              "format": "uuid",
              "description": "If replying inside a thread, the parent reply ID."
            }
          },
          "required": [
            "postId",
            "body"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_conversations",
        "title": "List my conversations",
        "description": "List direct-message conversations the signed-in user participates in, ordered by most recent activity. Includes other participants' user IDs and the last-message timestamp.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "description": "Max conversations to return, 1-50. Default 20."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_conversation",
        "title": "Get conversation messages",
        "description": "Fetch messages in a conversation the signed-in user participates in. Returns messages newest-first up to `limit` (default 50, max 200). Voice-note messages include an `audio_url` (signed URL not resolved here — treat as opaque storage path).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "conversationId": {
              "type": "string",
              "format": "uuid",
              "description": "Conversation ID (from list_conversations)."
            },
            "limit": {
              "type": "integer",
              "description": "Max messages, 1-200. Default 50."
            }
          },
          "required": [
            "conversationId"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "send_message",
        "title": "Send a message",
        "description": "Send a text message in a conversation the signed-in user participates in. RLS enforces participation; other members will receive an in-app notification via existing triggers.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "conversationId": {
              "type": "string",
              "format": "uuid",
              "description": "Conversation ID."
            },
            "body": {
              "type": "string",
              "minLength": 1,
              "description": "Message text."
            }
          },
          "required": [
            "conversationId",
            "body"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_mentorships",
        "title": "List my mentorships",
        "description": "List mentorship relationships the signed-in user is part of (as mentor or mentee), optionally filtered by status.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "organizationId": {
              "type": "string",
              "format": "uuid",
              "description": "Optional org filter."
            },
            "status": {
              "type": "string",
              "enum": [
                "pending",
                "active",
                "declined",
                "ended"
              ],
              "description": "Optional status filter."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "request_mentorship",
        "title": "Request mentorship",
        "description": "Send a mentorship request to another org member. The signed-in user becomes the mentee and the target user becomes the mentor. The other party will receive an in-app notification and must accept before the mentorship becomes active.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "organizationId": {
              "type": "string",
              "format": "uuid",
              "description": "Organization the mentorship is in."
            },
            "mentorUserId": {
              "type": "string",
              "format": "uuid",
              "description": "User ID of the desired mentor."
            },
            "introMessage": {
              "type": "string",
              "description": "Optional message to introduce yourself."
            }
          },
          "required": [
            "organizationId",
            "mentorUserId"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_ce_courses",
        "title": "List CE courses",
        "description": "List published Continuing Education courses in an organization that the signed-in user has access to (self-enroll or assigned). Includes credit hours and lesson counts.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "organizationId": {
              "type": "string",
              "format": "uuid",
              "description": "Organization ID."
            }
          },
          "required": [
            "organizationId"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_ce_course",
        "title": "Get CE course with progress",
        "description": "Fetch a Continuing Education course by ID including its lessons in order and the signed-in user's enrollment status and per-lesson progress.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "courseId": {
              "type": "string",
              "format": "uuid",
              "description": "Course ID."
            }
          },
          "required": [
            "courseId"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_website_pages",
        "title": "List website pages",
        "description": "List website builder pages in an organization the signed-in user belongs to. Includes drafts, scheduled, published, and archived pages.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "organizationId": {
              "type": "string",
              "format": "uuid",
              "description": "Organization ID."
            },
            "status": {
              "type": "string",
              "enum": [
                "draft",
                "published",
                "scheduled",
                "archived"
              ],
              "description": "Optional status filter."
            }
          },
          "required": [
            "organizationId"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_website_page",
        "title": "Get website page",
        "description": "Fetch a website builder page's full metadata plus its ordered sections (section_type, settings, content, visibility). Useful for reviewing or auditing a page's structure.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "pageId": {
              "type": "string",
              "format": "uuid",
              "description": "Page ID (from list_website_pages)."
            }
          },
          "required": [
            "pageId"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
